# 当前服务器推荐：纯运行态 compose 只拉取预构建镜像，不在服务器执行 pnpm install / build。
# 把 <your-owner> 替换成你的 GitHub 用户或组织，并按需把 main 改成某个 sha-* 标签。
API_IMAGE=ghcr.io/<your-owner>/frontend-interview-bank-api:main
APP_IMAGE=ghcr.io/<your-owner>/frontend-interview-bank-web:main
ADMIN_IMAGE=ghcr.io/<your-owner>/frontend-interview-bank-admin:main

# 对外暴露端口（避免和现有 nest-admin / vue-admin 冲突）
API_HOST_PORT=36000
APP_HOST_PORT=36080
ADMIN_HOST_PORT=36081
MYSQL_HOST_PORT=33307

# Docker 数据库配置
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=frontend_interview_bank
MYSQL_USER=interview_app
MYSQL_PASSWORD=change_me_app_password
