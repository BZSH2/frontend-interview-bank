# 运行态镜像（推荐由 GitHub Actions hosted runner 构建并发布到 GHCR）
API_RUNTIME_IMAGE=ghcr.io/bzsh2/frontend-interview-bank-api:main
APP_RUNTIME_IMAGE=ghcr.io/bzsh2/frontend-interview-bank-web:main
ADMIN_RUNTIME_IMAGE=ghcr.io/bzsh2/frontend-interview-bank-admin:main

# 运行态端口（runtime compose 默认只绑定到 127.0.0.1，公网入口交给 Caddy / 域名）
API_HOST_PORT=36000
APP_HOST_PORT=36080
ADMIN_HOST_PORT=36081
MYSQL_HOST_PORT=33307

# Docker 数据库配置
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=frontend_interview_bank
MYSQL_USER=interview_app
MYSQL_PASSWORD=change_me_app_password
