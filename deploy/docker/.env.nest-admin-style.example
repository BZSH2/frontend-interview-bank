# 本文件用于 docker-compose.nest-admin-style.yml 在本地/CI 端构建镜像。
# 当前服务器推荐使用 .env.runtime + docker-compose.nest-admin-style.runtime.yml。

# 对外暴露端口（避免和现有 nest-admin / vue-admin 冲突）
API_HOST_PORT=36000
APP_HOST_PORT=36080
ADMIN_HOST_PORT=36081
MYSQL_HOST_PORT=33307

# 前台 / 后台镜像构建时注入的 API 地址。
# 推荐保持为 /api，由各自的 Nginx 容器反代到 interview-bank-api。
APP_H5_API_BASE_URL=/api
ADMIN_WEB_API_BASE_URL=/api

# 如果开启后台鉴权，可在本地构建时显式注入。
# 注意：该值会被打进静态资源，仅适合受控环境。
ADMIN_WEB_TOKEN=

# Docker 数据库配置
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=frontend_interview_bank
MYSQL_USER=interview_app
MYSQL_PASSWORD=change_me_app_password
