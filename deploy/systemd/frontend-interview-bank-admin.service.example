[Unit]
Description=Frontend Interview Bank Admin Static Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/root/.openclaw/workspace/frontend-interview-bank
ExecStart=/usr/local/bin/node scripts/serve-static.mjs --root /root/.openclaw/workspace/frontend-interview-bank/admin-web/dist --port 4174
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
