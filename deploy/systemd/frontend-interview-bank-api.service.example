[Unit]
Description=Frontend Interview Bank API Server
After=network.target docker.service

[Service]
Type=simple
WorkingDirectory=/root/.openclaw/workspace/frontend-interview-bank/api-server
EnvironmentFile=/root/.openclaw/workspace/frontend-interview-bank/api-server/.env
ExecStart=/usr/local/bin/node dist/main.js
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target
