# 本地开发默认值。
# 如果使用 deploy/docker/docker-compose.nest-admin-style.runtime.yml，
# 其中的 PORT / DATABASE_URL 会由 compose 自动覆盖。
PORT=3000
DATABASE_URL=mysql://interview_app:interview_app_123@127.0.0.1:33306/frontend_interview_bank
GITHUB_OWNER=BZSH2
GITHUB_REPO=frontend-interview-bank
# 可选：配置后，访问 /api/admin/* 需要携带相同的 x-admin-token
ADMIN_TOKEN=
# 可选：不填也能本地跑通，只有创建 GitHub Issue 时才需要
GITHUB_TOKEN=

# 配好后可执行：pnpm --filter api-server sync:github-issues
