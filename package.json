{
  "name": "frontend-interview-bank",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend interview question bank monorepo with uni-app client and NestJS API.",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:uni:h5": "pnpm --filter app-uni dev:h5",
    "dev:uni:mp": "pnpm --filter app-uni dev:mp-weixin",
    "dev:api": "pnpm --filter api-server start:dev",
    "lint": "eslint . --ext .js,.cjs,.mjs,.ts,.vue --cache",
    "lint:fix": "eslint . --ext .js,.cjs,.mjs,.ts,.vue --fix",
    "format": "prettier . --write",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm lint && pnpm typecheck",
    "prepare": "husky",
    "dev:admin": "pnpm --filter admin-web dev",
    "bootstrap:dev": "sh scripts/bootstrap-dev.sh",
    "build:all": "sh scripts/build-all.sh",
    "smoke:test": "sh scripts/smoke-test.sh",
    "preview:all": "sh scripts/run-preview.sh",
    "serve:static": "node scripts/serve-static.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.23.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-vue": "^9.33.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "vue-eslint-parser": "^10.1.1"
  }
}
